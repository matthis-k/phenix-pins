{
  "version": 2,
  "profiles": {
    "git-hook": {
      "phase": "verify",
      "selection": "staged",
      "tasks": ["nixfmt-check", "statix-check", "deadnix-check"],
      "contexts": ["local"]
    },
    "manual": {
      "phase": "verify",
      "selection": "changed",
      "tasks": ["nixfmt-check", "statix-check", "deadnix-check", "nix-flake-check"],
      "contexts": ["local"]
    },
    "full": {
      "phase": "verify",
      "selection": "full",
      "tasks": ["nixfmt-check", "statix-check", "deadnix-check", "nix-flake-check"],
      "contexts": ["local"]
    },
    "pre-push": {
      "phase": "verify",
      "selection": "full",
      "tasks": ["nixfmt-check", "statix-check", "deadnix-check", "nix-flake-check"],
      "contexts": ["local"]
    },
    "ci": {
      "phase": "verify",
      "selection": "git-range",
      "tasks": ["nixfmt-check", "statix-check", "deadnix-check", "nix-flake-check"],
      "contexts": ["ci"]
    },
    "fix": {
      "phase": "fix",
      "selection": "staged",
      "tasks": ["nixfmt-fix", "statix-fix", "deadnix-fix"],
      "contexts": ["local"]
    }
  },
  "contexts": {
    "local": {
      "implementation": "local",
      "allow_mutation": true,
      "allow_interactive": false,
      "allow_network": true,
      "require_sandbox_safe": false
    },
    "ci": {
      "implementation": "local",
      "allow_mutation": false,
      "allow_interactive": false,
      "allow_network": true,
      "require_sandbox_safe": false
    }
  },
  "node": {
    "id": "phenix-pins",
    "description": "Verify the shared Phenix upstream pin surface",
    "tags": ["pins", "nixpkgs", "bootstrap"],
    "tasks": [
      {
        "id": "nixfmt-check",
        "description": "Check Nix formatting",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["*.nix", "**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["nixfmt", "--check"],
            "file_args": "matched",
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "statix-check",
        "description": "Lint Nix files with Statix",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["*.nix", "**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["statix", "check", "--ignore", ".git/**"],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "deadnix-check",
        "description": "Reject dead Nix code",
        "phase": "verify",
        "when": {
          "changed": {
            "paths": ["*.nix", "**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["deadnix", "--fail", "--no-lambda-arg", "--no-lambda-pattern-names"],
            "sandbox_safe": true
          }
        }
      },
      {
        "id": "nix-flake-check",
        "description": "Run the complete pin flake gate",
        "phase": "verify",
        "always": true,
        "implementations": {
          "local": {
            "kind": "command",
            "command": ["nix", "flake", "check", "--print-build-logs", "--keep-going"],
            "network": true,
            "sandbox_safe": false
          }
        }
      },
      {
        "id": "nixfmt-fix",
        "description": "Apply Nix formatting",
        "phase": "fix",
        "when": {
          "changed": {
            "paths": ["*.nix", "**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["nixfmt"],
            "file_args": "matched",
            "mutates": true
          }
        }
      },
      {
        "id": "statix-fix",
        "description": "Apply safe Statix fixes",
        "phase": "fix",
        "when": {
          "changed": {
            "paths": ["*.nix", "**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["statix", "fix"],
            "mutates": true
          }
        }
      },
      {
        "id": "deadnix-fix",
        "description": "Remove dead Nix code",
        "phase": "fix",
        "when": {
          "changed": {
            "paths": ["*.nix", "**/*.nix"]
          }
        },
        "implementations": {
          "default": {
            "kind": "command",
            "command": ["deadnix", "--edit", "--no-lambda-arg", "--no-lambda-pattern-names"],
            "mutates": true
          }
        }
      }
    ]
  }
}
