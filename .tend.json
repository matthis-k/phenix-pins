{
  "$schema": "https://phenix.local/schemas/tend.schema.json",
  "version": 1,
  "node": {
    "id": "phenix-pins",
    "description": "Phenix shared nixpkgs and tooling pins checks",
    "tags": ["pins", "nixpkgs"],
    "context": {
      "workdir": "."
    },
    "tasks": [
      {
        "id": "nixfmt-check",
        "description": "Check Nix files are formatted correctly",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "format"],
        "command": ["bash", "-c", "find . -name '*.nix' -not -path './.git/*' -print0 | xargs -0 -r nixfmt --check"],
        "expect": { "status": 0 }
      },
      {
        "id": "statix-check",
        "description": "Lint Nix files with statix",
        "phase": "verify",
        "kind": "command",
        "mutates": false,
        "sandbox_safe": true,
        "profiles": ["git-hook", "pre-push", "manual", "nix-check"],
        "tags": ["nix", "lint"],
        "command": ["statix", "check", "--ignore", ".git/**"],
        "expect": { "status": 0 }
      },
      {
        "id": "nix-flake-check",
        "description": "Full Nix flake evaluation check",
        "phase": "verify",
        "kind": "command",
        "command": ["nix", "flake", "check"],
        "profiles": ["manual"],
        "tags": ["nix", "full"],
        "sandbox_safe": false,
        "mutates": false,
        "interactive": false
      }
    ]
  }
}
